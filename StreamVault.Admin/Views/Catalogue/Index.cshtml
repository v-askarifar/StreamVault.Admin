@model StreamVault.Admin.ViewModels.CatalogueListViewModel

@{
    ViewData["Title"] = "Catalogue";
}

<div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3 mb-4">
    <div>
        <h1 class="fw-bold mb-1">Catalogue</h1>
        <p class="text-muted mb-0">Manage movies, series, audiobooks and music albums.</p>
    </div>

    <a asp-action="Create" class="btn btn-primary add-content-btn">
        + Add Content
    </a>
</div>

<div class="card border-0 shadow-sm mb-4 filter-card">
    <div class="card-body">
        <form method="get" class="row g-3">
            <div class="col-12 col-md-5">
                <label class="form-label">Search by title</label>
                <input name="search"
                       value="@Model.Search"
                       class="form-control"
                       placeholder="e.g. Inception"
                       autocomplete="off" />
            </div>

            <div class="col-12 col-md-4">
                <label class="form-label">Filter by type</label>
                <select name="type" class="form-select">
                    <option value="">All types</option>
                    <option value="Movie" selected="@(Model.SelectedType == "Movie")">Movie</option>
                    <option value="Series" selected="@(Model.SelectedType == "Series")">Series</option>
                    <option value="Audiobook" selected="@(Model.SelectedType == "Audiobook")">Audiobook</option>
                    <option value="MusicAlbum" selected="@(Model.SelectedType == "MusicAlbum")">Music Album</option>
                </select>
            </div>

            <div class="col-12 col-md-3 d-flex flex-column flex-sm-row align-items-stretch align-items-md-end gap-2">
                <button class="btn btn-outline-primary flex-fill">Apply</button>
                <a asp-action="Index" class="btn btn-outline-secondary flex-fill">Reset</a>
            </div>
        </form>
    </div>
</div>

@if (!Model.Items.Any())
{
    <div class="alert alert-info">
        No catalogue items found.
    </div>
}
else
{
    <div class="d-none d-lg-block card border-0 shadow-sm">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-dark">
                    <tr>
                        <th>Title</th>
                        <th>Type</th>
                        <th>Details</th>
                        <th>Genre</th>
                        <th>Age Rating</th>
                        <th>Release Date</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var item in Model.Items)
                    {
                        <tr>
                            <td>
                                <div class="fw-semibold">@item.Title</div>
                                <div class="small text-muted text-truncate catalogue-description">
                                    @item.Description
                                </div>
                            </td>

                            <td>
                                <span class="badge @item.TypeBadgeClass">@item.ContentTypeName</span>
                                
                            </td>

                            <td>@item.SpecificSummary</td>

                            <td>@item.Genre</td>
                            <td>@item.AgeRating</td>
                            <td>@item.ReleaseDate.ToString("yyyy-MM-dd")</td>

                            <td class="text-end">
                                <div class="d-inline-flex gap-2">
                                    <a asp-action="Edit"
                                       asp-route-publicId="@item.PublicId"
                                       class="btn btn-sm btn-outline-primary">
                                        Edit
                                    </a>

                                    <button type="button"
                                            class="btn btn-sm btn-outline-danger"
                                            data-bs-toggle="modal"
                                            data-bs-target="#deleteModal"
                                            data-delete-public-id="@item.PublicId"
                                            data-delete-title="@item.Title">
                                        Delete
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <div class="d-lg-none">
        <div class="row g-3">
            @foreach (var item in Model.Items)
            {
                <div class="col-12">
                    <div class="card border-0 shadow-sm catalogue-mobile-card">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-start gap-2 mb-2">
                                <div>
                                    <h5 class="fw-bold mb-1">@item.Title</h5>
                                    <span class="badge @item.TypeBadgeClass">@item.ContentTypeName</span>
                                    
                                </div>

                                <div class="small text-muted mt-1">@item.SpecificSummary</div>


                                <span class="small text-muted text-nowrap">
                                    @item.ReleaseDate.ToString("yyyy-MM-dd")
                                </span>
                            </div>

                            @if (!string.IsNullOrWhiteSpace(item.Description))
                            {
                                <p class="text-muted small mb-3">
                                    @item.Description
                                </p>
                            }

                            <div class="row small mb-3 g-2">
                                <div class="col-6">
                                    <div class="mobile-meta-box">
                                        <span class="text-muted d-block">Genre</span>
                                        <strong>@item.Genre</strong>
                                    </div>
                                </div>

                                <div class="col-6">
                                    <div class="mobile-meta-box">
                                        <span class="text-muted d-block">Rating</span>
                                        <strong>@item.AgeRating</strong>
                                    </div>
                                </div>
                            </div>

                            <div class="d-grid gap-2">
                                <a asp-action="Edit"
                                   asp-route-publicId="@item.PublicId"
                                   class="btn btn-outline-primary btn-sm">
                                    Edit
                                </a>

                                <button type="button"
                                        class="btn btn-outline-danger btn-sm"
                                        data-bs-toggle="modal"
                                        data-bs-target="#deleteModal"
                                        data-delete-public-id="@item.PublicId"
                                        data-delete-title="@item.Title">
                                    Delete
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
}

<div class="modal fade" id="deleteModal" tabindex="-1" aria-labelledby="deleteModalTitle" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg rounded-4">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title fw-bold" id="deleteModalTitle">
                    Delete content?
                </h5>

                <button type="button"
                        class="btn-close"
                        data-bs-dismiss="modal"
                        aria-label="Close"></button>
            </div>

            <div class="modal-body">
                <p class="mb-1">Are you sure you want to delete this item?</p>
                <p class="fw-semibold text-danger mb-0" id="deleteItemTitle"></p>

                <p class="small text-muted mt-3 mb-0">
                    This action cannot be undone.
                </p>
            </div>

            <div class="modal-footer border-0">
                <button type="button"
                        class="btn btn-outline-secondary"
                        data-bs-dismiss="modal">
                    Cancel
                </button>

                <form id="deleteForm" method="post">
                    @Html.AntiForgeryToken()

                    <button type="submit" class="btn btn-danger">
                        Yes, delete
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const deleteModal = document.getElementById('deleteModal');

        if (deleteModal) {
            deleteModal.addEventListener('show.bs.modal', function (event) {
                const button = event.relatedTarget;
                const publicId = button.getAttribute('data-delete-public-id');
                const itemTitle = button.getAttribute('data-delete-title');

                document.getElementById('deleteItemTitle').textContent = itemTitle;
                document.getElementById('deleteForm').action = `/Catalogue/Delete?publicId=${publicId}`;
            });
        }
    </script>
}